<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Partial Info.plist. GENERATE_INFOPLIST_FILE stays YES — Xcode merges its
  generated keys + every INFOPLIST_KEY_* (project.yml) into this file at build
  time. We only declare what has no INFOPLIST_KEY_ shorthand: the bundled fonts.
  Warm Bloom: Hanken Grotesk (UI) + Newsreader italic (clay accent lines).
-->
<plist version="1.0">
<dict>
	<key>UIAppFonts</key>
	<array>
		<string>HankenGrotesk-Regular.ttf</string>
		<string>HankenGrotesk-Medium.ttf</string>
		<string>HankenGrotesk-SemiBold.ttf</string>
		<string>HankenGrotesk-Bold.ttf</string>
		<string>HankenGrotesk-ExtraBold.ttf</string>
		<string>Newsreader-Italic.ttf</string>
		<string>Newsreader-MediumItalic.ttf</string>
	</array>
</dict>
</plist>
