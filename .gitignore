functions/.env.*
.runtimeconfig.json
functions/.runtimeconfig.json

# Service-account / admin keys
*serviceAccount*.json
*-adminsdk-*.json

# Apple signing material
*.p12
*.p8
*.cer
*.mobileprovision

# Android (future Kotlin app)
android/.gradle/
android/local.properties

# macOS
.DS_Store

# Claude Code local settings (machine-specific)
.claude/settings.local.json
