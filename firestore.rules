rules_version = '2';

// Each user can read/write only their own subtree (entries, day rollups, profile).
// Anonymous auth still yields a stable uid, so this holds before Sign in with Apple (M4).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
